generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  brand
  creator
  admin
}

enum Platform {
  instagram
  tiktok
  youtube
  facebook
}

enum ContentType {
  post
  reel
  story
  video
  short
}

enum CampaignStatus {
  draft
  active
  completed
  cancelled
}

enum ContractStatus {
  pending_signature
  active
  draft_submitted
  draft_approved
  post_live
  timer_running
  payment_released
  disputed
  cancelled
}

enum EscrowStatus {
  locked
  release_pending
  released
  refunded
}

enum SubmissionStatus {
  pending_review
  revision_requested
  approved
  live
  verified
  deleted
}

enum DisputeStatus {
  open
  under_review
  resolved_creator
  resolved_brand
}

enum NotificationType {
  new_application
  offer_received
  contract_signed
  draft_submitted
  draft_approved
  draft_revision
  post_verified
  payment_released
  dispute_opened
  dispute_resolved
}

enum PaymentMethod {
  card
  jazzcash
  easypaisa
  bank_transfer
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        UserRole
  avatarUrl   String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brandProfile      BrandProfile?
  creatorProfile    CreatorProfile?
  notifications     Notification[]
  disputesRaised    Dispute[]       @relation("DisputeRaisedBy")
  disputesModerated Dispute[]       @relation("DisputeModeratedBy")

  @@map("users")
}

model BrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String
  industry       String
  website        String?
  rating         Float    @default(0)
  totalCampaigns Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  contracts Contract[] @relation("BrandContracts")

  @@map("brand_profiles")
}

model CreatorProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String   @default("")
  niche        String   @default("")
  city         String   @default("")
  rating       Float    @default(0)
  totalDeals   Int      @default(0)
  availability String   @default("available")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts SocialAccount[]
  packages       Package[]
  contracts      Contract[]      @relation("CreatorContracts")

  @@map("creator_profiles")
}

model SocialAccount {
  id             String    @id @default(cuid())
  creatorId      String
  platform       Platform
  username       String
  platformUserId String
  followers      Int       @default(0)
  engagementRate Float     @default(0)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  isVerified     Boolean   @default(false)
  phylloUserId   String?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@map("social_accounts")
}

model Package {
  id           String      @id @default(cuid())
  creatorId    String
  title        String
  platform     Platform
  contentType  ContentType
  price        Decimal     @db.Decimal(12, 2)
  deliveryDays Int         @default(7)
  description  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  creator   CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  contracts Contract[]     @relation("PackageContracts")

  @@map("packages")
}

model Campaign {
  id           String         @id @default(cuid())
  brandId      String
  title        String
  platform     Platform
  contentType  ContentType
  brief        String
  budget       Decimal        @db.Decimal(12, 2)
  deadline     DateTime
  minFollowers Int            @default(0)
  maxRevisions Int            @default(2)
  status       CampaignStatus @default(active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  brand     BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contracts Contract[]   @relation("CampaignContracts")

  @@map("campaigns")
}

model Contract {
  id            String         @id @default(cuid())
  brandId       String
  creatorId     String
  campaignId    String?
  packageId     String?
  platform      Platform
  contentType   ContentType
  amount        Decimal        @db.Decimal(12, 2)
  deadline      DateTime
  maxRevisions  Int            @default(2)
  revisionsUsed Int            @default(0)
  status        ContractStatus @default(pending_signature)
  pdfUrl        String?
  brandSignedAt   DateTime?
  creatorSignedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  brand      BrandProfile       @relation("BrandContracts",    fields: [brandId],   references: [id])
  creator    CreatorProfile     @relation("CreatorContracts",  fields: [creatorId], references: [id])
  campaign   Campaign?          @relation("CampaignContracts", fields: [campaignId],references: [id])
  package    Package?           @relation("PackageContracts",  fields: [packageId], references: [id])
  escrow     EscrowTransaction?
  drafts     ContentDraft[]
  submission ContentSubmission?
  disputes   Dispute[]
  messages   Message[]

  @@map("contracts")
}

model EscrowTransaction {
  id            String        @id @default(cuid())
  contractId    String        @unique
  totalAmount   Decimal       @db.Decimal(12, 2)
  platformFee   Decimal       @db.Decimal(12, 2)
  creatorPayout Decimal       @db.Decimal(12, 2)
  status        EscrowStatus  @default(locked)
  paymentMethod PaymentMethod
  paymobOrderId String?
  paymobRef     String?
  lockedAt      DateTime      @default(now())
  releasedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("escrow_transactions")
}

model ContentDraft {
  id             String           @id @default(cuid())
  contractId     String
  version        Int              @default(1)
  fileUrls       String[]
  caption        String
  hashtags       String           @default("")
  status         SubmissionStatus @default(pending_review)
  revisionReason String?
  submittedAt    DateTime         @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("content_drafts")
}

model ContentSubmission {
  id          String           @id @default(cuid())
  contractId  String           @unique
  draftId     String?
  postUrl     String
  postId      String?
  platform    Platform
  status      SubmissionStatus @default(pending_review)
  verifiedAt  DateTime?
  timerEndsAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  disputes Dispute[]

  @@map("content_submissions")
}

model Dispute {
  id             String        @id @default(cuid())
  contractId     String
  submissionId   String?
  raisedByUserId String
  reason         String
  evidenceUrls   String[]      @default([])
  status         DisputeStatus @default(open)
  moderatorId    String?
  resolution     String?
  createdAt      DateTime      @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime      @updatedAt

  contract    Contract           @relation(fields: [contractId], references: [id])
  submission  ContentSubmission? @relation(fields: [submissionId], references: [id])
  raisedBy    User               @relation("DisputeRaisedBy",    fields: [raisedByUserId], references: [id])
  moderatedBy User?              @relation("DisputeModeratedBy", fields: [moderatorId],    references: [id])

  @@map("disputes")
}

model Message {
  id         String   @id @default(cuid())
  contractId String
  senderId   String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("platform_settings")
}
